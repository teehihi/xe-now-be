@startuml Architecture
package "Client Layer" {
  [React Application (Vite)] as React
}
package "Security Layer" {
  [Spring Security Filter] as Sec
}
package "Controller Layer" {
  [RestControllers] as API
}
package "Service Layer" {
  [Business Logic Services] as Services
}
package "Data Access Layer" {
  [Spring Data JPA Repositories] as Repos
}
database "MySQL" as DB

React --> Sec : JSON over HTTP
Sec --> API
API --> Services
Services --> Repos
Repos --> DB
@enduml
